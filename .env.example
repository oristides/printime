# Printime Configuration — copy to .env and fill in your values

# Printer settings
PRINTER_DEVICE=/dev/usb/lp5
PRINTER_WIDTH=48
PRINTER_BACKEND=usb
PRINTER_CUPS_QUEUE=POS8370

# HTTP Server
SERVER_PORT=8080

# Anytype Desktop API (optional)
ANYTYPE_API_URL=http://127.0.0.1:31009
ANYTYPE_API_KEY=your-desktop-api-key-here

# Google Calendar private ICS URL (optional)
GOOGLE_CALENDAR_ICS_URL=https://calendar.google.com/calendar/ical/YOUR_EMAIL/private-SECRET/basic.ics
GOOGLE_CALENDAR_TIMEZONE=America/Sao_Paulo

# LaTeX (optional, for equation template)
LATEX_COMMAND=pdflatex
PDF_TO_PNG_COMMAND=pdftoppm
LATEX_SCALE=150
